{
  "name": "auto-settle",
  "version": "0.1.0",
  "description": "Automatically settle Splitwise debts with PayNow QR codes. CLI + MCP server.",
  "main": "dist/cli/index.js",
  "bin": {
    "auto-settle": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "splitwise",
    "paynow",
    "sgqr",
    "mcp",
    "settle",
    "debt",
    "singapore"
  ],
  "author": "Jacky Li",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.0.0",
    "paynowqr": "^1.1.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "splitwise": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yuanfengli168/auto-settle.git"
  }
